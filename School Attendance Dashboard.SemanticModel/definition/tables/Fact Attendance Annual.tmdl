			RETURN
				CALCULATE(
					DIVIDE(SUM('Fact Attendance Annual'[OverallAbsenceSessions]), SUM('Fact Attendance Annual'[SessionsPossible])),
					FILTER(ALL('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear),
					REMOVEFILTERS('Dim Geography'),
					REMOVEFILTERS('Dim School Type'),
					'Dim Geography'[GeographyLevel] = "National",
					'Dim School Type'[SchoolType] = "Total"
