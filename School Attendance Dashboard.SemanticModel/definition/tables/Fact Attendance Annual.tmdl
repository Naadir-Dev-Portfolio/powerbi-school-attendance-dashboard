	measure 'National Latest Attendance Rate' = 1 - [National Latest Absence Rate]
		formatString: 0.0%
		lineageTag: a1f10e02-1023-4001-9001-000000000023

	measure 'National Latest Absence Rate YoY Change' =
			VAR LatestYear =
				CALCULATE(MAX('Dim Date'[AcademicYearSort]), ALL('Dim Date'))
			VAR Cur =
				CALCULATE(
					DIVIDE(SUM('Fact Attendance Annual'[OverallAbsenceSessions]), SUM('Fact Attendance Annual'[SessionsPossible])),
					FILTER(ALL('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear),
					REMOVEFILTERS('Dim Geography'),
					REMOVEFILTERS('Dim School Type'),
					'Dim Geography'[GeographyLevel] = "National",
					'Dim School Type'[SchoolType] = "Total"
				)
			VAR Prev =
				CALCULATE(
					DIVIDE(SUM('Fact Attendance Annual'[OverallAbsenceSessions]), SUM('Fact Attendance Annual'[SessionsPossible])),
					FILTER(ALL('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear - 1),
					REMOVEFILTERS('Dim Geography'),
					REMOVEFILTERS('Dim School Type'),
					'Dim Geography'[GeographyLevel] = "National",
					'Dim School Type'[SchoolType] = "Total"
				)
			RETURN (Cur - Prev) * 100
		formatString: +0.0;-0.0;0.0
		lineageTag: a1f10e02-1030-4001-9001-000000000030

	measure 'National Latest Persistent Absence YoY Change' =
			VAR LatestYear =
				CALCULATE(MAX('Dim Date'[AcademicYearSort]), ALL('Dim Date'))
			VAR Cur =
				CALCULATE(
					DIVIDE(SUM('Fact Attendance Annual'[PersistentAbsentees]), SUM('Fact Attendance Annual'[Enrolments])),
					FILTER(ALL('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear),
					REMOVEFILTERS('Dim Geography'),
					REMOVEFILTERS('Dim School Type'),
					'Dim Geography'[GeographyLevel] = "National",
					'Dim School Type'[SchoolType] = "Total"
				)
			VAR Prev =
				CALCULATE(
					DIVIDE(SUM('Fact Attendance Annual'[PersistentAbsentees]), SUM('Fact Attendance Annual'[Enrolments])),
					FILTER(ALL('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear - 1),
					REMOVEFILTERS('Dim Geography'),
					REMOVEFILTERS('Dim School Type'),
					'Dim Geography'[GeographyLevel] = "National",
					'Dim School Type'[SchoolType] = "Total"
				)
			RETURN (Cur - Prev) * 100
		formatString: +0.0;-0.0;0.0
		lineageTag: a1f10e02-1031-4001-9001-000000000031

