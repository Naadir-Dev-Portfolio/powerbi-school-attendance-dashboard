table 'Fact Attendance Annual'
	lineageTag: 6213c80a-3465-403f-a26b-b5c5fedd0491

	measure 'Pupil Enrolments' = SUM('Fact Attendance Annual'[Enrolments])
		formatString: #,##0
		lineageTag: 9e2027fe-7b23-4bca-a17d-06bd214b5696

	measure Schools = SUM('Fact Attendance Annual'[NumSchools])
		formatString: #,##0
		lineageTag: e26ed93d-40d3-4580-a05d-5f96b9d373c6

	measure 'Absence Rate' = DIVIDE(SUM('Fact Attendance Annual'[OverallAbsenceSessions]), SUM('Fact Attendance Annual'[SessionsPossible]))
		formatString: 0.0%
		lineageTag: d8bbe789-0be8-4ee8-b70e-b786258154da

	measure 'Attendance Rate' = 1 - [Absence Rate]
		formatString: 0.0%
		lineageTag: 5302c779-0cf3-440f-a84c-549da1d4df68

	measure 'Authorised Absence Rate' = DIVIDE(SUM('Fact Attendance Annual'[AuthorisedAbsenceSessions]), SUM('Fact Attendance Annual'[SessionsPossible]))
		formatString: 0.0%
		lineageTag: 66cdedcf-b4d0-4ad5-9a0f-459df01432bd

	measure 'Unauthorised Absence Rate' = DIVIDE(SUM('Fact Attendance Annual'[UnauthorisedAbsenceSessions]), SUM('Fact Attendance Annual'[SessionsPossible]))
		formatString: 0.0%
		lineageTag: d302f642-28bb-443a-8fbd-636871f12333

	measure 'Persistent Absentees' = SUM('Fact Attendance Annual'[PersistentAbsentees])
		formatString: #,##0
		lineageTag: 2e901ebd-37fd-49a0-be06-65de8a482f6d

	measure 'Persistent Absence Rate' = DIVIDE(SUM('Fact Attendance Annual'[PersistentAbsentees]), SUM('Fact Attendance Annual'[Enrolments]))
		formatString: 0.0%
		lineageTag: 86742825-b031-4e17-81df-31adbbd6ff88

	measure 'Severe Absentees' = SUM('Fact Attendance Annual'[SevereAbsentees])
		formatString: #,##0
		lineageTag: 843a4323-9a09-4111-b770-757aaee1aa64

	measure 'Severe Absence Rate' = DIVIDE(SUM('Fact Attendance Annual'[SevereAbsentees]), SUM('Fact Attendance Annual'[Enrolments]))
		formatString: 0.0%
		lineageTag: fe92706e-2794-4a96-8ae6-07a25d4148a0

	measure 'Illness Absence Rate' = AVERAGE('Fact Attendance Annual'[IllnessAbsenceRateSource])
		formatString: 0.0%
		lineageTag: 5bf46cf0-092b-4085-8293-bfd00fbd9c41

	measure 'Unauthorised Holiday Absence Rate' = AVERAGE('Fact Attendance Annual'[UnauthorisedHolidayAbsenceRateSource])
		formatString: 0.0%
		lineageTag: aab98cc7-b533-4168-921c-a5bd3db76073

	measure 'Latest Academic Year Sort' = CALCULATE(MAX('Dim Date'[AcademicYearSort]), REMOVEFILTERS('Dim Date'))
		formatString: 0
		lineageTag: e8411ef8-08b8-4a42-a2fb-58b285ebd1d8

	measure 'Latest Attendance Rate' =
			VAR LatestYear = [Latest Academic Year Sort]
			RETURN
			    CALCULATE(
			        [Attendance Rate],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[AcademicYearSort] = LatestYear
			    )
		formatString: 0.0%
		lineageTag: 782e5370-6ca2-4bd3-a791-701208f3651c

	measure 'Latest Absence Rate' =
			VAR LatestYear = [Latest Academic Year Sort]
			RETURN
			    CALCULATE(
			        [Absence Rate],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[AcademicYearSort] = LatestYear
			    )
		formatString: 0.0%
		lineageTag: 5d9ab6ea-f6a5-4e8d-a68d-38abd015984c

	measure 'Latest Persistent Absence Rate' =
			VAR LatestYear = [Latest Academic Year Sort]
			RETURN
			    CALCULATE(
			        [Persistent Absence Rate],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[AcademicYearSort] = LatestYear
			    )
		formatString: 0.0%
		lineageTag: eca478eb-3236-4a72-9afe-abfb275ca05c

	measure 'Latest Severe Absence Rate' =
			VAR LatestYear = [Latest Academic Year Sort]
			RETURN
			    CALCULATE(
			        [Severe Absence Rate],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[AcademicYearSort] = LatestYear
			    )
		formatString: 0.0%
		lineageTag: a18ebbc1-fe38-4d84-adeb-0bf8cea7bf41

	measure 'Absence Rate YoY Change' =
			VAR CurrentYear = MAX('Dim Date'[AcademicYearSort])
			VAR CurrentValue = [Absence Rate]
			VAR PreviousValue =
			    CALCULATE(
			        [Absence Rate],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[AcademicYearSort] = CurrentYear - 1
			    )
			RETURN
			    (CurrentValue - PreviousValue) * 100
		formatString: +0.0;-0.0;0.0
		lineageTag: 736b4222-b59b-4f5f-9e12-b4758458baf9

	measure 'Persistent Absence YoY Change' =
			VAR CurrentYear = MAX('Dim Date'[AcademicYearSort])
			VAR CurrentValue = [Persistent Absence Rate]
			VAR PreviousValue =
			    CALCULATE(
			        [Persistent Absence Rate],
			        REMOVEFILTERS('Dim Date'),
			        'Dim Date'[AcademicYearSort] = CurrentYear - 1
			    )
			RETURN
			    (CurrentValue - PreviousValue) * 100
		formatString: +0.0;-0.0;0.0
		lineageTag: c5d000ef-6ab5-4968-9fe1-b8c26519b151

	measure 'Latest Absence Rate YoY Change' =
			VAR LatestYear = [Latest Academic Year Sort]
			VAR CurrentValue =
			    CALCULATE([Absence Rate], REMOVEFILTERS('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear)
			VAR PreviousValue =
			    CALCULATE([Absence Rate], REMOVEFILTERS('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear - 1)
			RETURN
			    (CurrentValue - PreviousValue) * 100
		formatString: +0.0;-0.0;0.0
		lineageTag: 39b882be-9205-4f10-9ac4-d2b7f7b57698

	measure 'Latest Persistent Absence YoY Change' =
			VAR LatestYear = [Latest Academic Year Sort]
			VAR CurrentValue =
			    CALCULATE([Persistent Absence Rate], REMOVEFILTERS('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear)
			VAR PreviousValue =
			    CALCULATE([Persistent Absence Rate], REMOVEFILTERS('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear - 1)
			RETURN
			    (CurrentValue - PreviousValue) * 100
		formatString: +0.0;-0.0;0.0
		lineageTag: bc65b53a-8061-4948-942a-8c9fbcf4bfc9

	measure 'Trend Flag' =
			VAR Change = [Latest Absence Rate YoY Change]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(Change), "No comparison",
			        Change > 0.25, "Worsening",
			        Change < -0.25, "Improving",
			        "Stabilising"
			    )
		lineageTag: 33b8efd6-699e-480a-8e84-100bbc9b7c2e

	measure 'Persistent Absence Pressure Flag' =
			VAR Rate = [Latest Persistent Absence Rate]
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(Rate), "No data",
			        Rate >= 0.25, "Serious risk",
			        Rate >= 0.20, "High pressure",
			        Rate >= 0.15, "Elevated",
			        "Lower pressure"
			    )
		lineageTag: 4c7510cf-a814-464e-b4c0-931c588d266a

	measure 'Local Authority Persistent Absence Rank' =
			VAR LatestYear = [Latest Academic Year Sort]
			RETURN
			    IF(
			        SELECTEDVALUE('Dim Geography'[GeographyLevel]) = "Local authority",
			        RANKX(
			            FILTER(
			                ALLSELECTED('Dim Geography'[GeographyKey], 'Dim Geography'[GeographyName], 'Dim Geography'[GeographyLevel]),
			                'Dim Geography'[GeographyLevel] = "Local authority"
			            ),
			            CALCULATE([Persistent Absence Rate], REMOVEFILTERS('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear),
			            ,
			            DESC,
			            Dense
			        )
			    )
		formatString: 0
		lineageTag: 2f67f229-2ad6-47c2-9e42-05a8203b9924

	measure 'Decision Maker Takeaway' =
			
			VAR AttendanceTrend = [Trend Flag]
			VAR PersistentRate = [Latest Persistent Absence Rate]
			VAR SevereRate = [Latest Severe Absence Rate]
			RETURN
			    "Attendance is "
			        & LOWER ( AttendanceTrend )
			        & "; latest persistent absence is "
			        & FORMAT ( PersistentRate, "0.0%" )
			        & " and severe absence is "
			        & FORMAT ( SevereRate, "0.0%" )
			        & "."
		lineageTag: 8f60ba78-1726-4782-a6f4-00d07eb32d51

	measure 'National Pupil Enrolments' =
			CALCULATE(
				SUM('Fact Attendance Annual'[Enrolments]),
				REMOVEFILTERS('Dim Geography'),
				REMOVEFILTERS('Dim School Type'),
				'Dim Geography'[GeographyLevel] = "National",
				'Dim School Type'[SchoolType] = "Total"
			)
		formatString: #,##0
		lineageTag: a1f10e02-1001-4001-9001-000000000001

	measure 'National Latest Pupil Enrolments' =
			VAR LatestYear =
				CALCULATE(MAX('Dim Date'[AcademicYearSort]), ALL('Dim Date'))
			RETURN
				CALCULATE(
					SUM('Fact Attendance Annual'[Enrolments]),
					FILTER(ALL('Dim Date'), 'Dim Date'[AcademicYearSort] = LatestYear),
					REMOVEFILTERS('Dim Geography'),
					REMOVEFILTERS('Dim School Type'),
					'Dim Geography'[GeographyLevel] = "National",
					'Dim School Type'[SchoolType] = "Total"
				)
		formatString: #,##0
		lineageTag: a1f10e02-1002-4001-9001-000000000002

	measure 'National Schools' =
