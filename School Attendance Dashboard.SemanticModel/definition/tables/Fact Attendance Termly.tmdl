table 'Fact Attendance Termly'
	lineageTag: af1bfd96-ec75-4ce6-a1a5-0aebd11a01a2

	measure 'Termly Absence Rate' = DIVIDE(SUM('Fact Attendance Termly'[OverallAbsenceSessions]), SUM('Fact Attendance Termly'[SessionsPossible]))
		formatString: 0.0%
		lineageTag: cd901fce-fd96-4ba9-9b24-4ff031bb1bd2

	measure 'Termly Attendance Rate' = 1 - [Termly Absence Rate]
		formatString: 0.0%
		lineageTag: bb8eef85-ef36-4b00-a350-154bd28abbd8

	measure 'Termly Persistent Absence Rate' = DIVIDE(SUM('Fact Attendance Termly'[PersistentAbsentees]), SUM('Fact Attendance Termly'[Enrolments]))
		formatString: 0.0%
		lineageTag: 782cb1d7-3058-4cd9-980c-91ed690aef67

	measure 'Termly Severe Absence Rate' = DIVIDE(SUM('Fact Attendance Termly'[SevereAbsentees]), SUM('Fact Attendance Termly'[Enrolments]))
		formatString: 0.0%
		lineageTag: 75d77d31-bebb-4842-801e-882f53840ea9

