	partition 'Fact Attendance Termly' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_attendance_termly.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"TermKey", type text},
						{"AcademicYearKey", type text},
						{"AcademicYearSort", Int64.Type},
						{"TermName", type text},
						{"TermSort", Int64.Type},
						{"GeographyKey", type text},
						{"SchoolTypeKey", type text},
						{"EducationPhase", type text},
						{"Enrolments", type number},
						{"SessionsPossible", type number},
						{"OverallAbsenceSessions", type number},
						{"AuthorisedAbsenceSessions", type number},
						{"UnauthorisedAbsenceSessions", type number},
						{"OverallAbsenceRateSource", type number},
						{"AttendanceRateSource", type number},
						{"PersistentAbsentees", type number},
						{"PersistentAbsenceRateSource", type number},
						{"SevereAbsentees", type number},
						{"SevereAbsenceRateSource", type number}
					}, "en-GB")
				in
					Typed

